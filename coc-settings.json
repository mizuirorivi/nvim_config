{
"languageserver": {
  "ccls": {
    "command": "ccls",
    "args": ["--log-file=/tmp/ccls.log"],
    "filetypes": ["c", "cc", "cpp", "c++", "objc", "objcpp"],
    "rootPatterns": [".git/",".ccls", "compile_commands.json", ".hg/"],
    "initializationOptions": {
        "cache": {
          "directory": "/tmp/ccls"
        },
        "clang": {
          "excludeArgs": [],
          "extraArgs": []
          
       }
      }
  }
},
"snippets.ultisnips.pythonPrompt": false
}
